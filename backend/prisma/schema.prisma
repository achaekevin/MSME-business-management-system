// ----------------------------------------------------------------------------
// LEAVE MANAGEMENT (Enhanced)
// ----------------------------------------------------------------------------

model LeaveType {
  id              String   @id @default(uuid())
  businessId      String
  name            String // Annual Leave, Sick Leave, Maternity, etc.
  code            String
  daysAllowed     Int // Number of days per year
  carryForward    Boolean  @default(false)
  requiresApproval Boolean @default(true)
  isPaid          Boolean  @default(true)
  description     String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  business      Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  leaveBalances EmployeeLeaveBalance[]

  @@unique([businessId, code])
  @@index([businessId])
  @@map("leave_types")
}

model EmployeeLeaveBalance {
  id          String   @id @default(uuid())
  employeeId  String
  leaveTypeId String
  year        Int
  allocated   Int
  used        Int      @default(0)
  remaining   Int
  carryForward Int     @default(0)
  updatedAt   DateTime @updatedAt

  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([employeeId, leaveTypeId, year])
  @@index([employeeId])
  @@map("employee_leave_balances")
}

model LeaveRequest {
  id            String    @id @default(uuid())
  employeeId    String
  leaveTypeId   String?
  startDate     DateTime  @db.Date
  endDate       DateTime  @db.Date
  days          Decimal   @db.Decimal(4, 1) // Allow half days
  reason        String?   @db.Text
  status        String    @default("pending") // pending | approved | rejected | cancelled
  approvedBy    String?
  approvedAt    DateTime?
  rejectedBy    String?
  rejectedAt    DateTime?
  rejectionReason String?
  coveringEmployeeId String?
  attachments   Json? // Array of file URLs
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
  @@map("leave_requests")
}

// ----------------------------------------------------------------------------
// ATTENDANCE MANAGEMENT (Enhanced)
// ----------------------------------------------------------------------------

model AttendancePolicy {
  id                String   @id @default(uuid())
  businessId        String
  name              String
  workingDaysPerWeek Int     @default(5)
  workingHoursPerDay Decimal @db.Decimal(4, 2)
  startTime         String // "09:00"
  endTime           String // "17:00"
  graceMinutes      Int     @default(15)
  halfDayHours      Decimal @db.Decimal(4, 2)
  weekendDays       Json // ["Saturday", "Sunday"]
  isDefault         Boolean  @default(false)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@map("attendance_policies")
}

model AttendanceRecord {
  id              String    @id @default(uuid())
  employeeId      String
  date            DateTime  @db.Date
  checkIn         DateTime?
  checkOut        DateTime?
  workHours       Decimal?  @db.Decimal(4, 2)
  overtime        Decimal   @default(0) @db.Decimal(4, 2)
  status          String    @default("present") // present | absent | late | half_day | on_leave | holiday
  lateBy          Int       @default(0) // minutes
  earlyLeave      Int       @default(0) // minutes
  notes           String?
  location        String? // GPS location or branch
  deviceId        String?
  approvedBy      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  employee Employee @relation("AttendanceRecords", fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
  @@map("attendance_records")
}

// ----------------------------------------------------------------------------
// PAYROLL MANAGEMENT (Enhanced)
// ----------------------------------------------------------------------------

model PayrollComponent {
  id          String   @id @default(uuid())
  businessId  String
  name        String
  code        String
  type        String // earning | deduction
  calculation String // fixed | percentage | formula
  amount      Decimal? @db.Decimal(12, 2)
  percentage  Decimal? @db.Decimal(5, 2)
  isTaxable   Boolean  @default(true)
  isStatutory Boolean  @default(false)
  isActive    Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())

  business           Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  employeeComponents EmployeePayrollComponent[]

  @@unique([businessId, code])
  @@index([businessId])
  @@map("payroll_components")
}

model EmployeePayrollComponent {
  id          String   @id @default(uuid())
  employeeId  String
  componentId String
  amount      Decimal? @db.Decimal(12, 2)
  percentage  Decimal? @db.Decimal(5, 2)
  isActive    Boolean  @default(true)
  effectiveFrom DateTime @default(now())
  effectiveTo   DateTime?

  employee  Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  component PayrollComponent @relation(fields: [componentId], references: [id])

  @@index([employeeId])
  @@map("employee_payroll_components")
}

model PayrollPeriod {
  id          String    @id @default(uuid())
  businessId  String
  name        String // "January 2026", "Week 1 July 2026"
  periodType  String // monthly | weekly | biweekly
  startDate   DateTime  @db.Date
  endDate     DateTime  @db.Date
  payDate     DateTime? @db.Date
  status      String    @default("draft") // draft | processing | approved | paid | cancelled
  totalGross  Decimal   @default(0) @db.Decimal(14, 2)
  totalDeductions Decimal @default(0) @db.Decimal(14, 2)
  totalNet    Decimal   @default(0) @db.Decimal(14, 2)
  processedBy String?
  processedAt DateTime?
  approvedBy  String?
  approvedAt  DateTime?
  // Accounting integration
  accountingStatus String? @default("pending") // pending | posted | reversed
  journalEntryId   String? @unique
  postedToAccountingAt DateTime?
  postedToAccountingBy String?
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  business     Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  payslips     PayrollSlip[]
  journalEntry JournalEntry?  @relation(fields: [journalEntryId], references: [id])

  @@unique([businessId, startDate, endDate])
  @@index([businessId])
  @@index([status])
  @@map("payroll_periods")
}

model PayrollSlip {
  id              String  @id @default(uuid())
  payrollPeriodId String
  employeeId      String
  basicSalary     Decimal @db.Decimal(12, 2)
  earnings        Json // Array of {component, amount}
  deductions      Json // Array of {component, amount}
  grossPay        Decimal @db.Decimal(12, 2)
  totalDeductions Decimal @db.Decimal(12, 2)
  netPay          Decimal @db.Decimal(12, 2)
  taxableIncome   Decimal @default(0) @db.Decimal(12, 2)
  taxAmount       Decimal @default(0) @db.Decimal(12, 2)
  workDays        Int
  paidDays        Int
  leaveDays       Int     @default(0)
  absentDays      Int     @default(0)
  overtimeHours   Decimal @default(0) @db.Decimal(5, 2)
  overtimeAmount  Decimal @default(0) @db.Decimal(12, 2)
  paymentMethod   String? // bank_transfer | cash | cheque
  paymentReference String?
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime @default(now())

  payrollPeriod PayrollPeriod @relation(fields: [payrollPeriodId], references: [id], onDelete: Cascade)
  employee      Employee      @relation("PayrollSlips", fields: [employeeId], references: [id])

  @@unique([payrollPeriodId, employeeId])
  @@index([employeeId])
  @@map("payroll_slips")
}

// ----------------------------------------------------------------------------
// PERFORMANCE MANAGEMENT (Enhanced)
// ----------------------------------------------------------------------------

model PerformanceMetric {
  id          String   @id @default(uuid())
  businessId  String
  name        String
  description String?
  category    String // productivity | quality | behavior | goals
  weight      Decimal  @default(1) @db.Decimal(3, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@map("performance_metrics")
}

model PerformanceCycle {
  id          String    @id @default(uuid())
  businessId  String
  name        String
  cycleType   String // annual | quarterly | monthly
  startDate   DateTime  @db.Date
  endDate     DateTime  @db.Date
  status      String    @default("active") // active | closed
  description String?
  createdAt   DateTime  @default(now())

  business Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  reviews  PerformanceReviewRecord[]

  @@index([businessId])
  @@map("performance_cycles")
}

model PerformanceReviewRecord {
  id                String    @id @default(uuid())
  cycleId           String
  employeeId        String
  reviewerId        String?
  reviewDate        DateTime? @db.Date
  overallRating     Decimal?  @db.Decimal(3, 2)
  ratings           Json? // Array of {metric, rating, comments}
  strengths         String?   @db.Text
  improvements      String?   @db.Text
  goals             Json? // Array of goals
  reviewerComments  String?   @db.Text
  employeeComments  String?   @db.Text
  status            String    @default("pending") // pending | completed | acknowledged
  acknowledgedAt    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  cycle    PerformanceCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  employee Employee         @relation("PerformanceReviews", fields: [employeeId], references: [id])

  @@unique([cycleId, employeeId])
  @@index([employeeId])
  @@map("performance_review_records")
}

// ----------------------------------------------------------------------------
// EMPLOYEE DOCUMENTS (Enhanced)
// ----------------------------------------------------------------------------

model DocumentType {
  id          String   @id @default(uuid())
  businessId  String
  name        String
  code        String
  required    Boolean  @default(false)
  expiryTracking Boolean @default(false)
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, code])
  @@index([businessId])
  @@map("document_types")
}

model EmployeeDocumentRecord {
  id            String    @id @default(uuid())
  employeeId    String
  documentTypeId String?
  name          String
  description   String?
  fileUrl       String
  fileSize      Int?
  mimeType      String?
  issueDate     DateTime? @db.Date
  expiryDate    DateTime? @db.Date
  isVerified    Boolean   @default(false)
  verifiedBy    String?
  verifiedAt    DateTime?
  uploadedBy    String?
  uploadedAt    DateTime  @default(now())

  employee Employee @relation("EmployeeDocuments", fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([expiryDate])
  @@map("employee_document_records")
}

